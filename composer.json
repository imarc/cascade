{
    "name": "imarc/cascade",
    "description": "Cascading soft deletes for Laravel Eloquent",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0|^11.0",
        "phpunit/phpunit": "^11.5.3"
    },
    "autoload": {
        "psr-4": {
            "Imarc\\Cascade\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Imarc\\Cascade\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
